# ---- Network ----
# stellar:testnet (default) or stellar:pubnet
STELLAR_NETWORK=stellar:testnet
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# HORIZON_URL=https://horizon-testnet.stellar.org

# ---- x402 paywall ----
# Testnet default: Coinbase facilitator (sponsored fees). Mainnet: OpenZeppelin Channels.
# FACILITATOR_URL=https://www.x402.org/facilitator
# FACILITATOR_API_KEY=            # required for OpenZeppelin Channels (mainnet)

# Where 0.5 XLM entry fees land. Defaults to the payout wallet's public key.
# PAY_TO_ADDRESS=G...

# ---- Prize payouts ----
# Hot wallet secret that pays XLM prizes. Fund it generously.
# Testnet: create + fund at https://lab.stellar.org/account/fund
PAYOUT_SECRET=S...

# ---- Game economics (defaults shown) ----
# ENTRY_FEE_XLM=0.5
# WHEEL_MAX_PLAYS=3
# TRIVIA_MAX_PLAYS=1
# TRIVIA_XLM_PER_CORRECT=2

# ---- State store (required on Vercel; optional locally) ----
# Add Upstash Redis via Vercel Marketplace — these get injected automatically.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# ---- Dev helpers (testnet only) ----
# Enables /api/dev/wallet + /api/dev/pay so you can test the full x402 flow
# without a real wallet. Never works on mainnet.
DEV_MODE=true
# DEV_PLAYER_SECRET=S...          # optional fixed test player
